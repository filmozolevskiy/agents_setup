# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit real credentials.

# ClickHouse (Phoenix analytics)
CLICKHOUSE_HOST=<host>
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=<user>
CLICKHOUSE_PASSWORD=<password>
CLICKHOUSE_DATABASE=default

# MySQL (genesis database)
MYSQL_HOST=<host>
MYSQL_PORT=3307
MYSQL_USER=<user>
MYSQL_PASSWORD=<password>
MYSQL_DATABASE=ota

# MongoDB (debug_logs / optimizer_logs)
MONGODB_URI=mongodb://<host>:27017/
MONGODB_DATABASE=ota

# Optional: local genesis checkout for code-aware questions
GENESIS_PATH=/absolute/path/to/genesis

# Optional: codebase-memory-mcp binary (usually ~/.local/bin/codebase-memory-mcp)
# CODEBASE_MEMORY_MCP=codebase-memory-mcp/

# QA automation (only needed for /qa_automation)
QA_ENV=staging
QA_STAGING_PREFIX=staging2
QA_WORKER_COUNT=1
# QA_CARD_POOL_JSON=/path/to/cards.json
QA_JWT_FH_SECRET=<flighthub jwt secret>
QA_JWT_JF_SECRET=<justfly jwt secret>
QA_TRACE=1
QA_VIDEO=0

# QA backoffice logins (Summit / Respro)
SUMMIT_USER=<email>
SUMMIT_PASS=<password>
RESPRO_USER=<user>
RESPRO_PASS=<password>
